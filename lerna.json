{
  "version": "2.0.0",
  "packages": ["packages/*"],
  "npmClient": "npm",
  "registry": "https://registry.npmjs.org/",
  "command": {
    "publish": {
      "ignoreChanges": ["*.md", "*.txt", "test/**", "example/**", "package.json"]
    },
    "bootstrap": {
      "npmClient": "cnpm"
    }
  },
  "npmClientArgs": ["--no-package-lock"]
}
